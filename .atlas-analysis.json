  "keyFeatures": [
    "One-keystroke element context extraction (Cmd+C or Ctrl+C)",
    "Automatic React component and file path detection",
    "Visual overlay with selection box, drag selection, and crosshair",
    "Plugin system with custom actions and lifecycle hooks",
    "AI agent integration with streaming support",
    "MCP (Model Context Protocol) server support",
    "Built-in integrations for Cursor, Claude Code, Copilot, and OpenCode",
    "Customizable themes and activation modes",
    "CLI tool for automated project setup",
    "React Fiber debugging and source mapping"
  ],
  "publicApiSurface": [
    "init() - Initialize React Grab",
    "ReactGrabAPI.activate() - Activate element selection mode",
    "ReactGrabAPI.deactivate() - Deactivate selection mode",
    "ReactGrabAPI.toggle() - Toggle activation state",
    "ReactGrabAPI.copyElement() - Programmatically copy element context",
    "ReactGrabAPI.getSource() - Get source file info for element",
    "ReactGrabAPI.registerPlugin() - Register custom plugin",
    "ReactGrabAPI.unregisterPlugin() - Remove plugin",
    "ReactGrabAPI.setOptions() - Update runtime options",
    "ReactGrabAPI.getState() - Get current state",
    "window.__REACT_GRAB__ - Global API instance",
    "commentPlugin - Built-in comment action plugin",
    "openPlugin - Built-in open file plugin",
    "generateSnippet() - Generate HTML snippet from element",
    "Plugin interface - Create custom plugins with actions and hooks",
    "AgentProvider interface - Integrate AI agent providers",
    "Theme interface - Customize visual appearance",
    "Options interface - Configure behavior"
  ]
